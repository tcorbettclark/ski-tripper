# PUBLIC_ prefix = exposed to the browser (client-side access)
# No PUBLIC_ prefix = only exposed to server-side (or tools).

# ── Hosting ──
PUBLIC_DOMAIN=ski-tripper.localhost
PUBLIC_POCKETBASE_DOMAIN=pb.ski-tripper.localhost

# ── Server ──
SERVER_HOSTNAME=localhost
SERVER_PORT=5173

# ── PocketBase ──
POCKETBASE_HOSTNAME=localhost
POCKETBASE_PORT=8090
POCKETBASE_ADMIN_EMAIL=your-superuser-email
POCKETBASE_ADMIN_PASSWORD=your-superuser-password

# ── External APIs ──
EXA_API_KEY=your-exa-api-key
OLLAMA_API_KEY=your-ollama-api-key

# ── Ollama Models (per task) ──
OLLAMA_MODEL_ENRICH=deepseek-v4-flash
OLLAMA_MODEL_AUDIT=kimi-k2.6
OLLAMA_MODEL_ANALYSIS=kimi-k2.6
OLLAMA_MODEL_PREFERENCE_SEARCH=minimax-m3
