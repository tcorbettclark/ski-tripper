# ── External APIs ──────────────────────────────────────────────
EXA_API_KEY=your-exa-api-key
OLLAMA_API_KEY=your-ollama-api-key
OLLAMA_MODEL=kimi-k2.6:cloud

# ── Caddy ──────────────────────────────────────────────────────
CADDY_DOMAIN=ski-tripper.localhost
CADDY_PB_DOMAIN=pb.ski-tripper.localhost
CADDY_SERVER_PORT=5173
CADDY_PB_PORT=8090

# ── Bun API Server ────────────────────────────────────────────
SERVER_HOSTNAME=ski-tripper.localhost
SERVER_PORT=5173

# ── PocketBase ────────────────────────────────────────────────
# PUBLIC_ prefix = exposed to the browser (client-side access)
# Browser goes through Caddy
PUBLIC_POCKETBASE_URL=https://pb.ski-tripper.localhost
# No PUBLIC_ prefix = server-side only (direct, bypassing Caddy)
POCKETBASE_URL=http://127.0.0.1:8090
POCKETBASE_ADMIN_EMAIL=your-superuser-email
POCKETBASE_ADMIN_PASSWORD=your-superuser-password