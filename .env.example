# PUBLIC_ prefix = exposed to the browser (client-side access).
# No PUBLIC_ prefix = only exposed to server-side (or tools).
#
# Copy this file to .env (for local dev) or .env.production (for deployment).
# Fill in real values for secrets; defaults are suitable for local development.

# ── Hosting ──
# Dev:     ski-tripper.localhost / pb.ski-tripper.localhost
# Prod:    ski-tripper.com / pb.ski-tripper.com
PUBLIC_DOMAIN=ski-tripper.localhost
PUBLIC_POCKETBASE_DOMAIN=pb.ski-tripper.localhost
# Dev:     "static" (relative to Caddy working directory)
# Prod:    "/opt/ski-tripper/output/static" (absolute path for systemd service)
STATIC_ROOT=static

# ── Server ──
SERVER_HOSTNAME=127.0.0.1
SERVER_PORT=5173

# ── PocketBase ──
POCKETBASE_HOSTNAME=127.0.0.1
POCKETBASE_PORT=8090
POCKETBASE_ADMIN_EMAIL=your-superuser-email
POCKETBASE_ADMIN_PASSWORD=your-superuser-password

# ── SMTP (required by pocketbase:config) ──
# Dev:  Mailpit on localhost:1025 (no auth, no TLS)
# Prod: Resend (see https://resend.com)
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_LOCAL_NAME=

# ── App (required by pocketbase:config) ──
APP_URL=
SENDER_ADDRESS=
HIDE_CONTROLS=

# ── External APIs ──
EXA_API_KEY=your-exa-api-key
OLLAMA_API_KEY=your-ollama-api-key

# ── Ollama Models (per task) ──
# Enrich with a good model (Could even use deepseek-v4-pro).
OLLAMA_MODEL_ENRICH=deepseek-v4-flash
# Use an independent model for auditing.
OLLAMA_MODEL_AUDIT=kimi-k2.6
# Use a faster and cheaper model for preference search.
OLLAMA_MODEL_PREFERENCE_SEARCH=minimax-m3
# Use a model with decent output and detail.
OLLAMA_MODEL_ANALYSIS=kimi-k2.6
