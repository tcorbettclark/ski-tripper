# Production environment for ski-tripper deployment
# Copy to /opt/ski-tripper/.env on the DO server

# ── Hosting ──
PUBLIC_DOMAIN=ski-tripper.com
PUBLIC_POCKETBASE_DOMAIN=pb.ski-tripper.com

# ── Server ──
# Inside Docker, use 127.0.0.1 (all services share the same network namespace)
SERVER_HOSTNAME=127.0.0.1
SERVER_PORT=5173

# ── PocketBase ──
POCKETBASE_HOSTNAME=127.0.0.1
POCKETBASE_PORT=8090
POCKETBASE_ADMIN_EMAIL=your-admin-email
POCKETBASE_ADMIN_PASSWORD=your-secure-password

# ── External APIs ──
EXA_API_KEY=your-exa-api-key
OLLAMA_API_KEY=your-ollama-api-key

# ── Ollama Models ──
OLLAMA_MODEL_ENRICH=deepseek-v4-flash
OLLAMA_MODEL_AUDIT=kimi-k2.6
OLLAMA_MODEL_PREFERENCE_SEARCH=minimax-m3
OLLAMA_MODEL_ANALYSIS=kimi-k2.6