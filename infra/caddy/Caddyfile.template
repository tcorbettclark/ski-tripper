(security_headers) {
	# Tell browsers to always use HTTPS for the next year, including subdomains
	Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
	# Prevent browsers from MIME-sniffing responses away from the declared content type
	X-Content-Type-Options "nosniff"
	# Block this site from being embedded in iframes on other origins (clickjacking protection)
	X-Frame-Options "DENY"
	# Disable legacy XSS filter — modern browsers don't need it and it can introduce vulnerabilities
	X-XSS-Protection "0"
	# Only send the origin when navigating to same-origin; strip referrer on cross-origin
	Referrer-Policy "strict-origin-when-cross-origin"
	# Disable browser APIs the app doesn't use
	Permissions-Policy "camera=(), microphone=(), geolocation=()"
	# Remove Server header to reduce fingerprinting
	-Server
}

__PUBLIC_DOMAIN__ {
	log

	# Compress responses to reduce bandwidth
	encode gzip zstd

	header {
		import security_headers
		# Restrict resource loading to known origins
		# wasm-unsafe-eval: ONNX Runtime WebAssembly compilation
		# blob: worker-src: ONNX Runtime Web Workers from blob URLs
		# unsafe-inline script-src: inline theme detection script in index.html
		# data: and blob: img-src: app icons
		# connect-src includes HuggingFace, Xet/CAS bridge (model weights), and jsDelivr (WASM files)
		Content-Security-Policy "default-src 'self'; script-src 'self' 'wasm-unsafe-eval' 'unsafe-inline'; worker-src 'self' blob:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob:; connect-src 'self' https://__PUBLIC_POCKETBASE_DOMAIN__ https://raw.githubusercontent.com https://huggingface.co https://*.xethub.hf.co https://cdn.jsdelivr.net; font-src 'self' https://fonts.gstatic.com; frame-ancestors 'none'"
	}

	# API endpoints — Bun server with SSE streaming for LLM responses
	handle /api/* {
		reverse_proxy __SERVER_HOSTNAME__:__SERVER_PORT__ {
			# Stream SSE responses immediately without buffering (needed for token-by-token LLM output)
			flush_interval -1
		}
	}

	# Auth SPA routes — serve index.html for client-side routing
	@authPaths path /verify /reset-password /confirm-email
	handle @authPaths {
		root * __STATIC_ROOT__
		header Cache-Control "no-cache"
		rewrite /index.html
		file_server
	}

	# Static files — serve directly; missing files get 404 via handle_errors below
	handle {
		root * __STATIC_ROOT__
		header Cache-Control "no-cache"
		file_server
	}

	# Custom error pages — serve 404.html for missing static files instead of
	# Caddy's default plain-text response
	handle_errors {
		@custom_err file /{err.status_code}.html /error.html
		handle @custom_err {
			rewrite {file_match.relative}
			file_server
		}
		respond "{err.status_code} {err.status_text}"
	}
}

__PUBLIC_POCKETBASE_DOMAIN__ {
	log

	# Compress responses to reduce bandwidth
	encode gzip zstd

	# Limit request body size — PocketBase recommends 10MB for file uploads
	request_body {
		max_size 10MB
	}

	header {
		import security_headers
		# CSP relaxed for PocketBase admin UI: inline scripts/eval, self connections, data/blob images
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' ws: wss:; font-src 'self'; frame-ancestors 'none'"
	}

	reverse_proxy __POCKETBASE_HOSTNAME__:__POCKETBASE_PORT__ {
		# PocketBase docs recommend 360s for long-running operations (backups, etc.)
		transport http {
			read_timeout 360s
		}
	}
}