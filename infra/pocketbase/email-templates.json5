{
  // Email templates for PocketBase auth collections.
  //
  // Applied by `bun run pocketbase:config` after settings are synced.
  // {APP_URL} and {APP_NAME} are PocketBase built-in placeholders resolved
  // at send-time, so they don't need environment interpolation here.
  // {OTP} is a PocketBase built-in placeholder for the one-time password code.

  users: {
    otpTemplate: {
      subject: 'Your {APP_NAME} verification code',
      body: '<p>Hello,</p>\n<p>Your verification code is: <strong>{OTP}</strong></p>\n<p><i>If you didn\'t request this code, please ignore this email.</i></p>\n<p>\n  Thanks,<br/>\n  {APP_NAME} team\n</p>',
    },
  },
}