{
  // PocketBase settings — single source of truth for dev and prod.
  //
  // Environment-specific values use "${ENV_VAR}" placeholders resolved by
  // `bun run pocketbase:config`. All 8 override vars must be set in .env
  // (dev) and .env.production (prod). See .env.example for descriptions.
  //
  // Dev:  Mailpit on localhost:1025 (no auth, no TLS)
  // Prod: Resend on smtp.resend.com (port 2465, implicit TLS)
  //       Use port 465 if not blocked by host (e.g. DigitalOcean blocks 465/587)

  smtp: {
    enabled: true,
    host: "${SMTP_HOST}",
    port: "${SMTP_PORT}",
    username: "${SMTP_USERNAME}",
    password: "${SMTP_PASSWORD}",
    authMethod: "PLAIN",
    tls: "${SMTP_TLS}",
    localName: "${SMTP_LOCAL_NAME}",
  },

  meta: {
    appName: "Ski Tripper",
    appURL: "${APP_URL}",
    senderName: "Ski Tripper",
    senderAddress: "${SENDER_ADDRESS}",
    hideControls: "${HIDE_CONTROLS}",
    accentColor: "#1055c9",
  },

  backups: {
    cron: "",
    cronMaxKeep: 3,
    s3: {
      enabled: false,
      bucket: "",
      region: "",
      endpoint: "",
      accessKey: "",
      secret: "",
      forcePathStyle: false,
    },
  },

  s3: {
    enabled: false,
    bucket: "",
    region: "",
    endpoint: "",
    accessKey: "",
    secret: "",
    forcePathStyle: false,
  },

  rateLimits: {
    rules: [
      { label: "*:auth", audience: "", duration: 3, maxRequests: 2 },
      { label: "*:create", audience: "", duration: 5, maxRequests: 20 },
      { label: "/api/batch", audience: "", duration: 1, maxRequests: 3 },
      { label: "/api/", audience: "", duration: 10, maxRequests: 300 },
    ],
    excludedIPs: [],
    enabled: true,
  },

  trustedProxy: {
    headers: ["X-Forwarded-For"],
    useLeftmostIP: false,
  },

  batch: {
    enabled: false,
    maxRequests: 50,
    timeout: 3,
    maxBodySize: 0,
  },

  logs: {
    maxDays: 5,
    minLevel: 0,
    logIP: true,
    logAuthId: false,
  },
}