{
  "name": "ski-tripper",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun build src/main.jsx --outdir dist --target browser --env 'PUBLIC_*' --watch & bun server.js",
    "build": "bun build src/main.jsx --outdir dist --target browser --env 'PUBLIC_*' --minify && cp index.html dist/",
    "preview": "bun server.js",
    "test": "bun test --max-concurrency 1",
    "test:watch": "bun test --watch --max-concurrency 1",
    "lint": "bun run standard --fix --ignore .agents .",
    "format": "bun run prettier --write ."
  },
  "dependencies": {
    "appwrite": "^23.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "threewords": "^0.0.1"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.8.8",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "globals": "^17.4.0",
    "node-appwrite": "^22.1.3",
    "prettier": "3.8.1",
    "standard": "^17.1.2"
  }
}
