{
  "name": "ski-tripper",
  "version": "0.0.0",
  "type": "module",
  "description": "Ski trip planning application",
  "author": "Timothy Corbett-Clark",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tcorbettclark/ski-tripper"
  },
  "homepage": "https://ski-tripper.appwrite.network",
  "keywords": [
    "ski",
    "trip",
    "planning",
    "vacation",
    "scheduling",
    "winter",
    "snow",
    "resort",
    "mountain",
    "travel",
    "booking"
  ],
  "scripts": {
    "dev": "bun build src/main.tsx --outdir dist --target browser --env 'PUBLIC_*' --watch & bun server.js",
    "build": "bun run build-resort-data && bun build src/main.tsx --outdir dist --target browser --env 'PUBLIC_*' --minify && cp index.html dist/ && cp -r public/flags dist/flags",
    "preview": "bun server.js",
    "test": "bun test --max-concurrency 1",
    "test:watch": "bun test --watch --max-concurrency 1",
    "typecheck": "bun tsc --noEmit",
    "lint": "biome lint --write",
    "format": "biome format --write",
    "check": "biome check --write",
    "ci": "biome ci",
    "cors-finder": "bash scripts/find-cors-test.sh",
    "db-admin": "bun run scripts/db-admin.ts",
    "seed-resorts": "bun run scripts/seed-resorts.ts",
    "enrich-resorts": "bun run scripts/enrich-resorts.ts",
    "encode-resorts": "bun run scripts/encode-resorts.ts",
    "build-resort-data": "bun run scripts/encode-resorts.ts build"
  },
  "dependencies": {
    "@braintree/sanitize-url": "^7.1.2",
    "@huggingface/transformers": "^4.2.0",
    "@tsparticles/engine": "^4.1.2",
    "@tsparticles/preset-snow": "^4.1.2",
    "ai-json-safe-parse": "^0.3.0",
    "appwrite": "^25.2.0",
    "dayjs": "^1.11.21",
    "exa-js": "^2.13.0",
    "leven": "^4.1.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.6",
    "react-virtuoso": "^4.18.7"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@happy-dom/global-registrator": "^20.9.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "commander": "^14.0.3",
    "globals": "^17.6.0",
    "lefthook": "^2.1.8",
    "node-appwrite": "^25.2.0",
    "ollama": "^0.6.3",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  }
}
