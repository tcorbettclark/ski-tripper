{
  "name": "ski-tripper",
  "version": "0.0.0",
  "type": "module",
  "description": "Ski trip planning application",
  "author": "Timothy Corbett-Clark",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tcorbettclark/ski-tripper"
  },
  "homepage": "https://www.ski-tripper.com",
  "keywords": [
    "ski",
    "trip",
    "planning",
    "vacation",
    "scheduling",
    "winter",
    "snow",
    "resort",
    "mountain",
    "travel",
    "booking"
  ],
  "scripts": {
    "dev": "bun run build:copy && concurrently -n client,playground,server,pb,caddy -c blue,magenta,green,yellow,cyan 'bun run dev:client' 'bun run dev:playground' 'bun run dev:server' 'bun run dev:pb' 'bun run dev:caddy'",
    "dev:client": "bun build src/client/main.tsx --outdir output/static --target browser --env 'PUBLIC_*' --watch --no-clear-screen",
    "dev:playground": "bun build src/playground/action-guide-test.tsx --outdir output/static/playground --target browser --watch --no-clear-screen",
    "dev:server": "bun build src/server/serve.ts --outdir output/server --target bun --watch --no-clear-screen",
    "dev:pb": "pocketbase serve --http 127.0.0.1:8090 --migrationsDir src/pb_migrations --dir pb_data",
    "dev:caddy": "sh -c 'set -a && . .env && exec caddy run'",
    "setup:caddy": "caddy trust",
    "build": "bun run build:client && bun run build:playground && bun run build:server && bun run build:copy",
    "build:client": "bun build src/client/main.tsx --outdir output/static --target browser --env 'PUBLIC_*' --minify",
    "build:playground": "bun build src/playground/action-guide-test.tsx --outdir output/static/playground --target browser --minify",
    "build:server": "bun build src/server/serve.ts --outdir output/server --target bun",
    "build:copy": "cp src/static/index.html output/static/ && cp -r src/static/flags output/static/flags && cp src/playground/index.html output/static/playground/ && mkdir -p output/pb_migrations && cp src/pb_migrations/*.js output/pb_migrations/ && cp Caddyfile output/",
    "preview": "sh -c 'set -a && . .env && exec bun output/server/serve.js'",
    "test": "bun test --max-concurrency 1",
    "test:watch": "bun test --watch --max-concurrency 1",
    "typecheck": "bun tsc --noEmit",
    "lint": "biome lint --write",
    "format": "biome format --write",
    "check": "biome check --write",
    "ci": "biome ci",
    "resorts": "bun run src/scripts/resorts.ts",
    "create-collections": "bun run src/scripts/create-collections.ts"
  },
  "dependencies": {
    "@braintree/sanitize-url": "^7.1.2",
    "@huggingface/transformers": "^4.2.0",
    "dayjs": "^1.11.21",
    "leven": "^4.1.0",
    "lucide-react": "^1.17.0",
    "pocketbase": "^0.27.0",
    "react": "^19.2.6",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-virtuoso": "^4.18.7",
    "canonical-json": "^0.4.0",
    "ollama": "^0.6.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@happy-dom/global-registrator": "^20.9.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "ai-json-safe-parse": "^0.3.0",
    "commander": "^14.0.3",
    "concurrently": "^10.0.3",
    "csv-parse": "^6.2.1",
    "exa-js": "^2.13.0",
    "lefthook": "^2.1.8",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  }
}
