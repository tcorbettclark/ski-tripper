{
  "name": "ski-tripper",
  "version": "0.0.0",
  "type": "module",
  "description": "Ski trip planning application",
  "author": "Timothy Corbett-Clark",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tcorbettclark/ski-tripper"
  },
  "homepage": "https://ski-tripper.appwrite.network",
  "keywords": [
    "ski",
    "trip",
    "planning",
    "vacation",
    "scheduling",
    "winter",
    "snow",
    "resort",
    "mountain",
    "travel",
    "booking"
  ],
  "scripts": {
    "dev": "bun build src/main.tsx --outdir dist --target browser --env 'PUBLIC_*' --watch & bun server.js",
    "build": "bun build src/main.tsx --outdir dist --target browser --env 'PUBLIC_*' --minify && cp index.html dist/",
    "preview": "bun server.js",
    "test": "bun test --max-concurrency 1",
    "test:watch": "bun test --watch --max-concurrency 1",
    "typecheck": "bun tsc --noEmit",
    "lint": "biome lint --write",
    "format": "biome format --write",
    "check": "biome check --write",
    "ci": "biome ci",
    "cors-finder": "bash scripts/find-cors-test.sh",
    "db-admin": "bun run scripts/db-admin.ts"
  },
  "dependencies": {
    "@braintree/sanitize-url": "^7.1.2",
    "appwrite": "^24.2.0",
    "dayjs": "^1.11.20",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "threewords": "^0.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@happy-dom/global-registrator": "^20.9.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "commander": "^14.0.3",
    "globals": "^17.6.0",
    "lefthook": "^2.1.6",
    "node-appwrite": "^23.1.0",
    "typescript": "^6.0.3"
  }
}
