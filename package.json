{
  "name": "ski-tripper",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun build src/main.tsx --outdir dist --target browser --env 'PUBLIC_*' --watch & bun server.js",
    "build": "bun build src/main.tsx --outdir dist --target browser --env 'PUBLIC_*' --minify && cp index.html dist/",
    "preview": "bun server.js",
    "test": "bun test --max-concurrency 1",
    "test:watch": "bun test --watch --max-concurrency 1",
    "typecheck": "bun tsc --noEmit",
    "lint": "biome lint --write",
    "format": "biome format --write",
    "check": "biome check --write",
    "ci": "biome ci"
  },
  "dependencies": {
    "appwrite": "^24.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "threewords": "^0.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@happy-dom/global-registrator": "^20.8.9",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "globals": "^17.4.0",
    "lefthook": "^2.1.4",
    "node-appwrite": "^23.0.0",
    "typescript": "^6.0.2"
  }
}
